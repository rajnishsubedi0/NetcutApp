<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0D1117"
    android:orientation="vertical"
    android:padding="8dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="8dp">

        <TextView
            android:id="@+id/tvCount"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Killed Devices"
            android:textColor="#58A6FF"
            android:textSize="16sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btnClearAll"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/button_danger_small"
            android:enabled="false"
            android:paddingHorizontal="16dp"
            android:paddingVertical="6dp"
            android:text="Clear All"
            android:textColor="#FFFFFF"
            android:textSize="12sp" />
    </LinearLayout>

    <TextView
        android:id="@+id/tvEmptyState"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginTop="64dp"
        android:gravity="center"
        android:text="🔍 No killed devices\n\nTap 'Kill' on a device to add it here"
        android:textColor="#8B949E"
        android:textSize="16sp"
        android:visibility="gone" />

    <ListView
        android:id="@+id/lvKilledDevices"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:divider="#21262D"
        android:dividerHeight="1dp"
        android:paddingVertical="4dp" />

</LinearLayout>