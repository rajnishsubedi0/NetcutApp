<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="?android:attr/selectableItemBackground"
    android:orientation="vertical"
    android:padding="14dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">
        <LinearLayout
            android:id="@+id/horizontalLinearLayoutForBg"
            android:background="@drawable/bg_for_item_view_green"
            android:gravity="center"
            android:layout_weight="89"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="8dp"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"/>
        <LinearLayout
            android:paddingStart="25dp"
            android:layout_weight="32"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">
            <TextView
                android:id="@+id/tvIp"
                android:text="192.168.1.1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#C9D1D9"
                android:textSize="16dp"
                android:textStyle="bold" />
            <TextView
                android:id="@+id/tvMac"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="AA:BB:CC:DD:EE:FF"
                android:textColor="#8B949E"
                android:textSize="13dp" />
            <TextView
                android:id="@+id/tvVendor"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Unknown"
                android:textColor="#8B949E"
                android:textSize="13dp" />
        </LinearLayout>


            <Button
                android:layout_weight="60"
                android:layout_margin="2dp"
                android:id="@+id/tvStatusBadge"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:text="Cut"
                android:background="@drawable/border_for_listview_items_red"
                android:textColor="#4CAF50"
                android:textSize="14dp" />

    </LinearLayout>

</LinearLayout>