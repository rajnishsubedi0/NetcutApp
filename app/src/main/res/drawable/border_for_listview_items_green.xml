<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">

    <!-- Transparent center makes it an empty box surrounded by just a line -->
    <solid android:color="@android:color/transparent" />

    <!-- This defines the single line border width and color -->
    <stroke
        android:width="2dp"
        android:color="#4CAF50" /> <!-- Change hex color code as needed -->

    <!-- This curves the corners of your square -->
    <corners android:radius="25dp" />

</shape>
