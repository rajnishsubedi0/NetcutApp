<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Glow effect -->
    <item>
        <shape android:shape="rectangle">

            <solid android:color="#101018"/>

            <corners android:radius="50dp"/>

            <stroke
                android:width="3dp"
                android:color="#55FF5555"/>

        </shape>
    </item>


    <!-- Main border -->
    <item android:left="0.75dp"
        android:right="0.75dp"
        android:top="0.75dp"
        android:bottom="0.75dp">

        <shape android:shape="rectangle">

            <solid android:color="#11121A"/>

            <corners android:radius="50dp"/>

            <stroke
                android:width="0.75dp"
                android:color="#FFC107"/>

        </shape>

    </item>

</layer-list>